# Copy to terraform.tfvars and adjust. Never commit secrets.
# The DB password is generated automatically and stored in AWS Secrets Manager.

aws_region          = "eu-central-1"
project_name        = "flatrock-webapp"
environment         = "dev"
instance_type       = "t3.micro"
min_size            = 2
max_size            = 4
desired_capacity    = 2
db_engine           = "postgres"
db_name             = "appdb"
db_username         = "appadmin"
acm_certificate_arn = "arn:aws:acm:eu-central-1:123456789012:certificate/CHANGE-ME"
